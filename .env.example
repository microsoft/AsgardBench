# AsgardBench Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# OpenAI-Compatible API Configuration
# ============================================================================
# These variables configure the unified OpenAI-compatible client.
# The client works with: OpenAI, Azure OpenAI, OpenRouter, VLLM, and any
# OpenAI-compatible API endpoint.

# API Key for authentication (required)
OPENAI_API_KEY=your-api-key-here

# Base URL for the API endpoint (optional, defaults to OpenAI)
# Examples:
#   - OpenAI (default):     https://api.openai.com/v1
#   - Azure OpenAI:         https://your-resource.openai.azure.com
#   - OpenRouter:           https://openrouter.ai/api/v1
#   - Local VLLM:           http://localhost:8000/v1
#   - Custom endpoint:      https://your-custom-endpoint.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# API Version (required for Azure OpenAI)
# OPENAI_API_VERSION=2024-02-15-preview

# ============================================================================
# AsgardBench Configuration (optional)
# ============================================================================

# Directory where benchmark data is stored (default: Generated/)
# ASGARDBENCH_DATA_DIR=Generated

# Directory where test outputs are stored (default: Test/)
# ASGARDBENCH_TEST_DIR=Test

# Disable colored console output (set to 1 or true)
# ASGARDBENCH_NO_COLOR=false

# Enable quiet mode (less verbose output, set to 1 or true)
# ASGARDBENCH_QUIET=false
